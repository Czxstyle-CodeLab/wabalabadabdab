-- ║          CHINA HAT MODULE — Белый стиль              ║
-- ║          Только на носителе скрипта                  ║
-- ╚══════════════════════════════════════════════════════╝

local Players = game:GetService("Players")
local lp = Players.LocalPlayer
local RunService = game:GetService("RunService")

local module = {}
local hatPart = nil
local charConn = nil
local hatColor = {R = 100, G = 200, B = 255}

local function createHat()
    local part = Instance.new("Part")
    part.Name = "WexChinaHat"
    part.Anchored = false
    part.CanCollide = false
    part.Size = Vector3.new(3.5, 0.25, 3.5)
    part.Transparency = 0
    part.Material = Enum.Material.Neon
    part.Color = Color3.fromRGB(hatColor.R, hatColor.G, hatColor.B)
    part.CastShadow = false

    local mesh = Instance.new("SpecialMesh", part)
    mesh.MeshType = Enum.MeshType.FileMesh
    mesh.MeshId = "rbxassetid://1033714"
    mesh.Scale = Vector3.new(2.0, 0.9, 2.0)

    return part
end

local function addHatToChar(char)
    if not char then return end
    local head = char:WaitForChild("Head", 3)
    if not head then return end
    if hatPart then hatPart:Destroy() hatPart = nil end

    hatPart = createHat()
    hatPart.CFrame = head.CFrame * CFrame.new(0, 1.0, 0)
    hatPart.Parent = char

    local weld = Instance.new("WeldConstraint", hatPart)
    weld.Part0 = hatPart
    weld.Part1 = head
end

function module.Enable()
    if lp.Character then addHatToChar(lp.Character) end
    charConn = lp.CharacterAdded:Connect(function(char)
        task.wait(0.5)
        addHatToChar(char)
    end)
end

function module.Disable()
    if charConn then charConn:Disconnect() charConn = nil end
    if hatPart then hatPart:Destroy() hatPart = nil end
    -- Удаляем старые шляпы
    if lp.Character then
        for _, v in ipairs(lp.Character:GetChildren()) do
            if v.Name == "WexChinaHat" then v:Destroy() end
        end
    end
end

return module
